{
    "openapi": "3.0.1",
    "info": {
        "title": "Public API",
        "description": "Public API used to search for and download published notices",
        "version": "1.0"
    },
    "servers": [
        {
            "url": "https://api.doffin.no/public"
        }
    ],
    "paths": {
        "/v2/search": {
            "get": {
                "summary": "search",
                "description": "Search notices with given parameters.\n#### Example call \n```\ncurl -X 'GET' \\\n'https://api.doffin.no/public/v2/search?numHitsPerPage=2&page=2&estimatedValueFrom=1000000&estimatedValueTo=1000000000&status=EXPIRED' \\\n-H \"Ocp-Apim-Subscription-Key: <your-subscription-key>\" \n``` ",
                "operationId": "65015b9b566f983bdcfcaee8",
                "parameters": [
                    {
                        "name": "numHitsPerPage",
                        "in": "query",
                        "description": "total number of results (hits) displayed on a single page (Max value 100)",
                        "schema": {
                            "enum": [
                                20
                            ],
                            "type": "integer"
                        }
                    },
                    {
                        "name": "page",
                        "in": "query",
                        "description": "the current page of results",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "sortBy",
                        "in": "query",
                        "description": "the sort property. Example: 'sortBy=PUBLICATION_DATE_ASC'\n\ndefault: PUBLICATION_DATE_DESC",
                        "schema": {
                            "enum": [
                                "DEADLINE",
                                "RELEVANCE",
                                "PUBLICATION_DATE_ASC",
                                "PUBLICATION_DATE_DESC",
                                "ESTIMATED_VALUE_ASC",
                                "ESTIMATED_VALUE_DESC"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "searchString",
                        "in": "query",
                        "description": "the search text for filtering the dataset",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "type",
                        "in": "query",
                        "description": "the notice type:  Example multiple types: 'type=COMPETITION&type=RESULT'",
                        "schema": {
                            "enum": [
                                "PLANNING",
                                "NOTICE_ON_BUYER_PROFILE",
                                "ADVISORY_NOTICE",
                                "PRE_ANNOUNCEMENT",
                                "COMPETITION",
                                "ANNOUNCEMENT_OF_COMPETITION",
                                "DYNAMIC_PURCHASING_SCHEME",
                                "QUALIFICATION_SCHEME",
                                "RESULT",
                                "ANNOUNCEMENT_OF_INTENT",
                                "ANNOUNCEMENT_OF_CONCLUSION_OF_CONTRACT",
                                "CHANGE_OF_CONCLUSION_OF_CONTRACT",
                                "CANCELLED_OR_MISSING_CONCLUSION_OF_CONTRACT"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "description": "the notice status. Example multiple statues : 'status=ACTIVE&status=EXPIRED'",
                        "schema": {
                            "enum": [
                                "ACTIVE",
                                "EXPIRED",
                                "AWARDED",
                                "CANCELLED"
                            ],
                            "type": "string"
                        }
                    },
                    {
                        "name": "cpvCode",
                        "in": "query",
                        "description": "the cpv codes. Example multiple cpvCodes: 'cpvCode=1&cpvCode=2'",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "location",
                        "in": "query",
                        "description": "the location id. Example multiple locations: 'location=123&location=234'\nFor ikke angitt filter 'location=anyw'",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "issueDateFrom",
                        "in": "query",
                        "description": "Starting date in issue date range on format yyyy-mm-dd (from)",
                        "schema": {
                            "type": "localdate"
                        }
                    },
                    {
                        "name": "issueDateTo",
                        "in": "query",
                        "description": "End date in issue date range on format yyyy-mm-dd (to)",
                        "schema": {
                            "type": "localdate"
                        }
                    },
                    {
                        "name": "estimatedValueFrom",
                        "in": "query",
                        "description": "The estimated value in range (from) ",
                        "schema": {
                            "type": "long"
                        }
                    },
                    {
                        "name": "estimatedValueTo",
                        "in": "query",
                        "description": "The estimated value in range (to) ",
                        "schema": {
                            "type": "long"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The search response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PagedPublicNoticeDto"
                                },
                                "example": {
                                    "numHitsTotal": 0,
                                    "numHitsAccessible": 0,
                                    "hits": {
                                        "id": "string",
                                        "buyer": [
                                            {
                                                "id": "string",
                                                "organizationId": "string",
                                                "name": "string"
                                            }
                                        ],
                                        "heading": "string",
                                        "description": "string",
                                        "locationId": [
                                            "string"
                                        ],
                                        "estimatedValue": {
                                            "currencyCode": "string",
                                            "amount": 0
                                        },
                                        "type": "string",
                                        "allTypes": [
                                            "string"
                                        ],
                                        "issueDate": "string",
                                        "publicationDate": "string",
                                        "receivedTenders": 0,
                                        "allReceivedTenders": [
                                            {
                                                "type": "string",
                                                "total": "integer"
                                            }
                                        ],
                                        "cpvCodes": [
                                            "string"
                                        ],
                                        "lots": [
                                            {
                                                "heading": "string",
                                                "description": "string",
                                                "winner": [
                                                    {
                                                        "id": "string",
                                                        "organizationId": "string",
                                                        "name": "string"
                                                    }
                                                ]
                                            }
                                        ]
                                    }
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v2/download/{doffinId}": {
            "get": {
                "summary": "download",
                "description": "Download notice with given parameters.\n#### Example call \n```\ncurl -X 'GET' \\\n'https://api.doffin.no/public/v2/download/2023-100282' \\\n-H \"Ocp-Apim-Subscription-Key: <your-subscription-key>\" \n``` ",
                "operationId": "65015cc43a2729c87e6be1a8",
                "parameters": [
                    {
                        "name": "doffinId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "The downloaded notice",
                        "content": {
                            "application/octet-stream": {}
                        }
                    },
                    "404": {
                        "description": "Notice was not found",
                        "content": {
                            "application/json": {}
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "EFormStatusEnum": {
